{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "default_agent": "plan",
  "instructions": [
    "AGENTS.md",
    "docs/opencode/**/*.md"
  ],
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/build/**",
      "**/.turbo/**",
      "**/coverage/**",
      "**/.cache/**"
    ]
  },
  "permission": {
    "*": "ask",
    "bash": {
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "ls *": "allow",
      "pwd*": "allow",
      "cat *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "jq *": "allow",
      "sed *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "pnpm -r --if-present lint*": "ask",
      "pnpm -r --if-present typecheck*": "ask",
      "pnpm -r --if-present build*": "ask",
      "pnpm --filter @crypto-ai/api*": "ask",
      "pnpm --filter @crypto-ai/web*": "ask",
      "redis-cli *": "ask",
      "git push*": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "rm *": "deny",
      "docker *": "deny",
      "railway *": "deny"
    },
    "edit": "ask",
    "write": "ask"
  }
}
